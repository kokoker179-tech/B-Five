{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Store user specific information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Order": {
      "title": "Customer Order",
      "description": "Detailed order information for a purchase",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "completed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "shippingAddress": { "type": "object" }
      },
      "required": ["userId", "items", "total", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Public and private user profile data"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer purchase records"
    }
  }
}
